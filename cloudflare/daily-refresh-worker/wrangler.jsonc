{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "hangar-express-daily-refresh",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-29",
  "workers_dev": false,
  "preview_urls": false,
  "triggers": {
    "crons": [
      "0 9 * * *"
    ]
  },
  "observability": {
    "enabled": true
  }
}
